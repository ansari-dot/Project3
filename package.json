{
  "name": "saf-charity-website",
  "version": "1.0.0",
  "description": "SAF Charity Foundation website with React frontend and Node.js backend",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd ui && npm run dev",
    "build": "cd ui && npm run build",
    "start": "cd server && npm start",
    "install:all": "npm run install:server && npm run install:client",
    "install:server": "cd server && npm install",
    "install:client": "cd ui && npm install",
    "deploy": "npm run build && npm run start",
    "pm2:start": "cd server && npm run pm2:start",
    "pm2:stop": "cd server && npm run pm2:stop",
    "pm2:restart": "cd server && npm run pm2:restart",
    "pm2:logs": "cd server && npm run pm2:logs",
    "health": "curl http://localhost:4000/api/health"
  },
  "keywords": [
    "charity",
    "nonprofit",
    "react",
    "nodejs",
    "mongodb",
    "express"
  ],
  "author": "SAF Charity Foundation",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}